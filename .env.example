# =============================================================================
# KNG3 SHAMAN v1 — Binance 5m/15m signals -> Polymarket UP/DOWN (see README).
# =============================================================================
POLY_PRIVATE_KEY=replace_me
POLY_FUNDER=replace_me
POLY_SIGNATURE_TYPE=1
POLY_DRY_RUN=true

RELAYER_API_KEY=
RELAYER_SECRET=
RELAYER_PASSPHRASE=

BOT_STRATEGY_MODE=shaman_v1

BOT_LOG_LEVEL=INFO
BOT_POLL_INTERVAL_SECONDS=1.0
BOT_REQUEST_TIMEOUT_SECONDS=10.0

BOT_POLY_WS_ENABLED=true
BOT_POLY_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# PM slug discovery (15m BTC up/down)
BOT_WINDOW_MINUTES=15
BOT_MARKET_SYMBOL=BTC

BOT_BTC_FEED_SYMBOL=BTCUSDT
BOT_STRATEGY_NEW_ORDER_CUTOFF_SECONDS=30

# Budget default in code for shaman is $30 if unset
BOT_STRATEGY_BUDGET_CAP_USDC=30
BOT_STRATEGY_MIN_BUDGET_USDC=15

# --- SHAMAN v1 (optional overrides) ---
# BOT_SHAMAN_V1_RULES_PATH=/app/PALADIN/shaman_v1_rules.json
# BOT_SHAMAN_V1_KLINE_LIMIT=500
# BOT_SHAMAN_V1_PRICE_PAD=0.03
# BOT_SHAMAN_V1_NOTIONAL_BASE=3.0
# BOT_SHAMAN_V1_NOTIONAL_PER_EXTRA=1.0
# BOT_SHAMAN_V1_NOTIONAL_MAX=6.0
# BOT_SHAMAN_V1_MIN_SHARES=1
# BOT_SHAMAN_V1_MIN_NOTIONAL_USDC=1.0
