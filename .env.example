POLY_PRIVATE_KEY=replace_me
POLY_FUNDER=replace_me
POLY_SIGNATURE_TYPE=1
# Go live: set POLY_DRY_RUN=false after a successful dry-run deploy.
POLY_DRY_RUN=true
BOT_VERSION=paladin-v3-10sh-2026-04-21

RELAYER_API_KEY=
RELAYER_SECRET=
RELAYER_PASSPHRASE=

BOT_LOG_LEVEL=INFO
BOT_POLL_INTERVAL_SECONDS=1.0
BOT_REQUEST_TIMEOUT_SECONDS=10.0

# Mirror of kng_bot3: PALADIN v3 pair ladder (10/side, gap 100s, no trailing by default).
BOT_STRATEGY_MODE=paladin

BOT_POLY_WS_ENABLED=true
BOT_POLY_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
BOT_POLY_FAK_CONFIRM_ORDER=true

BOT_PALADIN_PAIR_SUM_MAX=1.0
BOT_PALADIN_TARGET_MIN_ROI=0
BOT_PALADIN_HEARTBEAT_SEC=15.0
BOT_PALADIN_STAGGER_PAIR=true
BOT_PALADIN_FIRST_LEG_MAX_PX=0.55
BOT_PALADIN_STAGGER_HEDGE_FORCE_SEC=45.0
BOT_PALADIN_MAX_SHARES_PER_SIDE=10
BOT_PALADIN_COOLDOWN_SEC=0.0
BOT_PALADIN_DYNAMIC_CLIP_CAP=12.0
BOT_PALADIN_PAIR_SUM_TIGHTEN_PER_FILL=0
BOT_PALADIN_PAIR_SUM_MIN_FLOOR=0.90
BOT_PALADIN_PENDING_HEDGE_BYPASS_IMBALANCE_SH=10
BOT_PALADIN_DISCIPLINE_RELAX_AFTER_FORCE_SEC=60
BOT_PALADIN_SECOND_LEG_BOOK_IMPROVE_EPS=0.013
BOT_PALADIN_MAX_BLENDED_PAIR_AVG_SUM=1.03
BOT_PALADIN_STAGGER_WINNING_SIDE_FIRST_WHEN_POSITION=false
BOT_PALADIN_STAGGER_SYMMETRIC_FALLBACK_WHEN_BALANCED=true
BOT_PALADIN_STAGGER_SYMMETRIC_FALLBACK_ROI_DISCOUNT=0.03
BOT_PALADIN_STAGGER_SYMMETRIC_FALLBACK_SKIP_FIRST_BLEND=true
BOT_PALADIN_STAGGER_ALTERNATE_FIRST_WHEN_BALANCED=true
BOT_PALADIN_MIN_ELAPSED_BETWEEN_PAIR_STARTS=100
# -1 = no trailing dip filter
BOT_PALADIN_ENTRY_TRAILING_MIN_LOW_SEC=-1
BOT_PALADIN_ENTRY_TRAILING_LOW_SLIPPAGE=0.02

BOT_SHARES_PER_LEVEL=5
BOT_VOLUME_SCALP_SHARES=6
BOT_VOLUME_SCALP_MAX_ORDERS_PER_SIDE=3
BOT_VOLUME_SCALP_ENTRY_MIN_ELAPSED=60
BOT_VOLUME_SCALP_ENTRY_MAX_ELAPSED=840
BOT_VOLUME_SCALP_VOLUME_RATIO=2.5
BOT_VOLUME_SCALP_TP_OFFSET=0.12
BOT_VOLUME_SCALP_STOP_OFFSET=0.05
BOT_VOLUME_SCALP_TIME_EXIT_SECONDS_REMAINING=60
BOT_STRATEGY_BUDGET_CAP_USDC=80.0
BOT_STRATEGY_WALLET_RESERVE_USDC=0.0
BOT_STRATEGY_MIN_BUDGET_USDC=15.0
BOT_STRATEGY_ENTRY_DELAY_SECONDS=24
BOT_STRATEGY_NEW_ORDER_CUTOFF_SECONDS=30
BOT_STRATEGY_STALE_ORDER_SECONDS=8
BOT_FORCE_EXIT_BEFORE_END_SECONDS=15
