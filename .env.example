POLY_PRIVATE_KEY=replace_me
POLY_FUNDER=replace_me
POLY_SIGNATURE_TYPE=1
POLY_DRY_RUN=true

RELAYER_API_KEY=
RELAYER_SECRET=
RELAYER_PASSPHRASE=

BOT_LOG_LEVEL=INFO
BOT_POLL_INTERVAL_SECONDS=1.0
BOT_REQUEST_TIMEOUT_SECONDS=10.0

# This image accepts paladin_v7 only.
BOT_STRATEGY_MODE=paladin_v7

BOT_POLY_WS_ENABLED=true
BOT_POLY_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Kept for compatibility / logging; current forced hedge logic is timeout-driven, not gated by mid_up + mid_dn.
BOT_PALADIN_V7_FORCED_HEDGE_SUM_MAX=1.30

# Our pair economics cap for cheap hedges (held VWAP + opposite + slip).
BOT_PALADIN_V7_CHEAP_PAIR_AVG_SUM_NONFORCED_MAX=0.96
# Spike-entry clip size and base hedge clip size.
BOT_PALADIN_V7_BASE_ORDER_SHARES=5
# Extra cap added to BTC-spike marketable buys so fast books still match reliably.
BOT_PALADIN_V7_SPIKE_MARKET_PRICE_BUFFER=0.02
# Max inventory per outcome.
BOT_PALADIN_V7_MAX_SHARES_PER_SIDE=20
# Legacy higher-VWAP dip threshold; spike-only mode no longer uses it for entries.
BOT_PALADIN_V7_LAYER2_DIP_BELOW_AVG=0.05
# Legacy layer tightening knob; spike-only mode no longer uses it for entries.
BOT_PALADIN_V7_LAYER_LEVEL_OFFSET_STEP=0.01
# Legacy lower-VWAP deep-dip threshold; spike-only mode no longer uses it for entries.
BOT_PALADIN_V7_LAYER2_LOW_VWAP_DIP_BELOW_AVG=0.20
# |up−down| <= this (shares) counts as balanced for BTC-spike re-entry checks.
BOT_PALADIN_V7_BALANCE_SHARE_TOLERANCE=1.0
# Imbalance repair: buy lighter side when pm_light + VWAP(heavy) < this (default 0.97).
BOT_PALADIN_V7_IMBALANCE_REPAIR_MAX_PAIR_SUM=0.97
# Legacy layer-entry cooldown; spike-only mode no longer uses a non-spike layer path.
BOT_PALADIN_V7_LAYER2_COOLDOWN_SEC=5
# Seconds after each completed pair before the next balanced BTC-spike entry.
BOT_PALADIN_V7_PAIR_COOLDOWN_SEC=5
# Cheap-hedge gate cushion vs opposite mid.
BOT_PALADIN_V7_CHEAP_HEDGE_SLIP_BUFFER=0.012
# Seconds after first leg before a *cheap* hedge may run (0 = next tick when gate passes). hedge_timeout is *forced* max age, not min gap.
BOT_PALADIN_V7_CHEAP_HEDGE_MIN_DELAY_SEC=0
# Force balancing / hedge after this many seconds.
BOT_PALADIN_V7_HEDGE_TIMEOUT_SEC=60
# Forced-hedge / non-persistent limit-buy cancel timer. Cheap hedge limits now rest until hedge timeout.
BOT_PALADIN_V7_LIMIT_ORDER_CANCEL_SEC=5
# Reconcile model balances vs API balances.
BOT_PALADIN_V7_RECONCILE_ENABLED=true
BOT_PALADIN_V7_RECONCILE_INTERVAL_SEC=5.0
BOT_PALADIN_V7_RECONCILE_SHARE_TOL=0.35
BOT_PALADIN_V7_RECONCILE_CONFIRM_READS=2
# If model looks balanced but API still shows skew, only trust API after these repeated checks.
BOT_PALADIN_V7_API_REALITY_CONFIRM_READS=5
BOT_PALADIN_V7_API_REALITY_CONFIRM_INTERVAL_SEC=2.0
BOT_PALADIN_V7_RECONCILE_FLATTEN=true
BOT_PALADIN_V7_RECONCILE_FLATTEN_MIN_IMB=0.25
BOT_PALADIN_V7_RECONCILE_FLATTEN_COOLDOWN_SEC=10.0

BOT_STRATEGY_BUDGET_CAP_USDC=80.0
BOT_STRATEGY_WALLET_RESERVE_USDC=0.0
BOT_STRATEGY_MIN_BUDGET_USDC=15.0
BOT_STRATEGY_ENTRY_DELAY_SECONDS=0
BOT_STRATEGY_NEW_ORDER_CUTOFF_SECONDS=30
BOT_FORCE_EXIT_BEFORE_END_SECONDS=15
